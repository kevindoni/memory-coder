# Environment Configuration

# ====== BRIDGE MODE ======
MEMORY_CODER_MODE=bridge
MEMORY_CODER_PORT=3333

# ====== SECURITY ======
# Set a strong random key to enable admin endpoint authentication
# If empty, admin endpoints are UNAUTHENTICATED (dev mode only)
MEMORY_CODER_API_KEY=your-secret-api-key-here

# ====== RATE LIMITING ======
# Requests per minute per IP
MEMORY_CODER_AI_RATE=20          # /v1/admin/ask, /capture
MEMORY_CODER_WRITE_RATE=120       # /remember, /log-bug, POST /memories

# ====== GIT INDEXER ======
# Auto-index git commits every N minutes (0 = disabled)
INDEXER_INTERVAL_MIN=360

# ====== LLM / OPENROUTER ======
# Required for AI features: /ask, /capture, smart-summary
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# LLM retry/timeout settings
LLM_MAX_RETRIES=2
LLM_TIMEOUT_MS=60000

# ====== FILE WATCHER ======
# Directory to watch for conversation capture files
CAPTURES_DIR=./captures
